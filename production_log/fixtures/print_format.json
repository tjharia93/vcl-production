[
 {
  "name": "Carton Job Card",
  "doctype": "Print Format",
  "doc_type": "Job Card Carton",
  "module": "Job Card Tracking",
  "print_format_type": "Jinja",
  "raw_printing": 0,
  "standard": "No",
  "custom_format": 1,
  "html": "<style>\n    /* GLOBAL PRINT SETTINGS */\n    @page { size: A4; margin: 10mm; }\n    .vcl-wrapper { font-family: 'Inter', Arial, sans-serif; color: #000; font-size: 10.5px; line-height: 1.2; }\n    .page-break { page-break-before: always; }\n\n    /* BRANDING & HEADERS */\n    .header-table { width: 100%; border-bottom: 3px solid #2B3990; margin-bottom: 8px; padding-bottom: 4px; }\n    .main-title { color: #2B3990; font-size: 20px; font-weight: 900; text-transform: uppercase; }\n    .sec-head { background: #2B3990; color: #fff; padding: 5px 8px; font-weight: 900; font-size: 10px; text-transform: uppercase; border-radius: 2px 2px 0 0; margin-top: 8px; }\n    .sec-head.alt { background: #00395D; }\n    .sec-head.dark { background: #333; }\n\n    /* BOXED GRID SYSTEM */\n    .dense-table { width: 100%; border-collapse: collapse; margin-bottom: 5px; table-layout: fixed; }\n    .dense-table td, .dense-table th { border: 1.5px solid #666; padding: 6px; vertical-align: top; word-wrap: break-word; }\n    .dense-table th { background: #eee; text-align: left; font-weight: 900; font-size: 9px; text-transform: uppercase; }\n\n    /* LABELS & VALUES */\n    .lbl { font-size: 8px; color: #00395D; font-weight: 900; text-transform: uppercase; display: block; margin-bottom: 2px; }\n    .val { font-weight: 900; color: #000; font-size: 12px; }\n    .board-box { border: 2px solid #000; padding: 8px; text-align: center; font-size: 16px; font-weight: 900; background: #fff; margin-top: 4px; }\n    .sig-line { border-top: 1.5px solid #000; width: 85%; margin: 20px auto 5px auto; }\n\n    /* SUB-HEADER FOR PAGES 2 & 3 */\n    .sub-header-grid { width: 100%; border-collapse: collapse; margin-bottom: 10px; }\n    .sub-header-grid td { border: 1px solid #ccc; padding: 4px 8px; font-size: 9px; }\n    .sub-header-grid .k { background: #f4f4f4; font-weight: 900; width: 15%; text-transform: uppercase; }\n\n    .qc-box { width: 15px; height: 15px; border: 1.5px solid #000; margin: 2px auto; }\n\n    /* DIE-CUT VISUALIZATION */\n    .die-cut-container { text-align: center; padding: 8px 0; }\n    .die-cut-container svg { max-width: 100%; }\n</style>\n\n{%- set board_w = doc.get(\"board_width_planned_mm\") | float if doc.get(\"board_width_planned_mm\") else 0 -%}\n{%- set board_l = doc.get(\"board_length_planned_mm\") | float if doc.get(\"board_length_planned_mm\") else 0 -%}\n{%- set area = (board_w / 1000.0) * (board_l / 1000.0) -%}\n\n{#- Take-up Factor Logic -#}\n{%- set flute_type = (doc.get(\"flute_type\") or \"\").upper() -%}\n{%- set factor = 1.7 if \"E\" in flute_type else 1.5 -%}\n\n{#- GSM Layers -#}\n{%- set gsm1 = doc.get(\"1_ply_top_layer_gsm\") | float if doc.get(\"1_ply_top_layer_gsm\") else 0 -%}\n{%- set gsm2 = doc.get(\"2_ply_fluting_gsm\") | float if doc.get(\"2_ply_fluting_gsm\") else 0 -%}\n{%- set gsm3 = doc.get(\"3_ply_bottom_gsm\") | float if doc.get(\"3_ply_bottom_gsm\") else 0 -%}\n{%- set gsm4 = doc.get(\"4_ply_fluting_gsm\") | float if doc.get(\"4_ply_fluting_gsm\") else 0 -%}\n{%- set gsm5 = doc.get(\"5_ply_fluting_gsm\") | float if doc.get(\"5_ply_fluting_gsm\") else 0 -%}\n\n{%- set ply = doc.get(\"ply\") or \"\" -%}\n{%- if ply == \"5\" -%}\n    {%- set unit_weight = (area * gsm1) + (area * gsm2 * factor) + (area * gsm3) + (area * gsm4 * factor) + (area * gsm5) -%}\n{%- else -%}\n    {%- set unit_weight = (area * gsm1) + (area * gsm2 * factor) + (area * gsm3) -%}\n{%- endif -%}\n\n{#- Material display string -#}\n{%- set mat1 = doc.get(\"1_ply_top_layer_material\") or \"\" -%}\n{%- set mat3 = doc.get(\"3_ply_top_layer_material\") or \"\" -%}\n\n{#- Product type for conditional rendering -#}\n{%- set product_type = doc.get(\"product_type\") or \"\" -%}\n{%- set joint_type = doc.get(\"joint_type\") or \"\" -%}\n{%- set L = doc.get(\"ctn_length_mm\") | int if doc.get(\"ctn_length_mm\") else 0 -%}\n{%- set W = doc.get(\"ctn_width_mm\") | int if doc.get(\"ctn_width_mm\") else 0 -%}\n{%- set H = doc.get(\"ctn_height_mm\") | int if doc.get(\"ctn_height_mm\") else 0 -%}\n{%- set flap = doc.get(\"ctn_flap_mm\") | int if doc.get(\"ctn_flap_mm\") else 0 -%}\n\n<div class=\"vcl-wrapper\">\n\n    <!-- PAGE 1: MASTER AUTHORIZATION -->\n    <div class=\"page-container\">\n        <table class=\"header-table\">\n            <tr>\n                <td>\n                    <div class=\"main-title\">Carton Job Traveler</div>\n                    <div style=\"font-size:10px; font-weight:900; color:#00395D;\">VIMIT CONVERTERS LTD &bull; MASTER AUTHORIZATION</div>\n                </td>\n                <td align=\"right\" width=\"30%\">\n                    <div style=\"border: 2px solid #2B3990; padding: 5px; text-align: center;\">\n                        <span class=\"lbl\">JOB CARD NO:</span>\n                        <div style=\"font-size: 16px; font-weight: 900; color: #2B3990;\">{{ doc.name }}</div>\n                    </div>\n                </td>\n            </tr>\n        </table>\n\n        <div class=\"sec-head\">1. Commercial & Order Details</div>\n        <table class=\"dense-table\">\n            <tr>\n                <td colspan=\"3\">\n                    <span class=\"lbl\">Customer Name</span>\n                    <span class=\"val\">{{ doc.get(\"customer_name\") or \"INTERNAL / STOCK\" }}</span>\n                    <div style=\"margin-top: 8px; border-top: 1px dashed #ccc; padding-top: 4px;\">\n                        <span class=\"lbl\">Job Description / Specific Remarks</span>\n                        <span class=\"val\" style=\"font-size: 11px; color: #333;\">{{ doc.get(\"job_description\") or \"N/A\" }}</span>\n                    </div>\n                </td>\n                <td>\n                    <span class=\"lbl\">Order / LPO No.</span>\n                    <span class=\"val\">________________</span>\n                    <div style=\"margin-top: 15px;\">\n                        <span class=\"lbl\">New / Repeat</span>\n                        <span class=\"val\">{{ doc.get(\"repeat\") or \"NEW\" }}</span>\n                    </div>\n                </td>\n            </tr>\n            <tr>\n                <td><span class=\"lbl\">Qty Ordered</span><span class=\"val\" style=\"font-size:16px;\">{{ doc.get(\"quantity_ordered\") or \"0\" }} PCS</span></td>\n                <td><span class=\"lbl\">Due Date</span><span class=\"val\">{{ frappe.utils.formatdate(doc.get(\"due_date\"), \"dd.mm.yyyy\") if doc.get(\"due_date\") else \"\" }}</span></td>\n                <td><span class=\"lbl\">Colours</span><span class=\"val\">{{ doc.get(\"colours_details\") or \"PLAIN\" }}</span></td>\n                <td><span class=\"lbl\">Date Created</span><span class=\"val\">{{ frappe.utils.formatdate(doc.creation, \"dd.mm.yyyy\") }}</span></td>\n            </tr>\n        </table>\n\n        <div class=\"sec-head alt\">2. Product Specifications (Carton Size)</div>\n        <table class=\"dense-table\">\n            <tr>\n                <td><span class=\"lbl\">Length (mm)</span><span class=\"val\">{{ L }}</span></td>\n                <td><span class=\"lbl\">Width (mm)</span><span class=\"val\">{{ W }}</span></td>\n                <td><span class=\"lbl\">Height (mm)</span><span class=\"val\">{{ H }}</span></td>\n                <td><span class=\"lbl\">Flap (mm)</span><span class=\"val\">{{ flap }}</span></td>\n                <td><span class=\"lbl\">Ply</span><span class=\"val\" style=\"font-size:16px;\">{{ ply or \"N/A\" }}</span></td>\n            </tr>\n            <tr>\n                <td colspan=\"2\">\n                    <span class=\"lbl\">Paper Combination / GSM Detail</span>\n                    <span class=\"val\">\n                        {%- if ply == \"5\" -%}\n                            {{ gsm1|int }} {{ mat1 }} / {{ gsm2|int }}F / {{ gsm3|int }} {{ mat3 }} / {{ gsm4|int }}F / {{ gsm5|int }}\n                        {%- elif ply == \"3\" -%}\n                            {{ gsm1|int }} {{ mat1 }} / {{ gsm2|int }}F / {{ gsm3|int }} {{ mat3 }}\n                        {%- elif ply == \"SFK\" -%}\n                            {{ gsm1|int }} {{ mat1 }} / {{ gsm2|int }}F\n                        {%- else -%}\n                            N/A\n                        {%- endif -%}\n                    </span>\n                </td>\n                <td><span class=\"lbl\">Flute Type</span><span class=\"val\">{{ doc.get(\"flute_type\") or \"N/A\" }}</span></td>\n                <td><span class=\"lbl\">Joint Type</span><span class=\"val\">{{ joint_type or \"N/A\" }}</span></td>\n                <td><span class=\"lbl\">Product Type</span><span class=\"val\">{{ product_type or \"N/A\" }}</span></td>\n            </tr>\n        </table>\n\n        <div class=\"sec-head\">3. Board Production & Calculated Weight</div>\n        <table class=\"dense-table\">\n            <tr>\n                <td><span class=\"lbl\">Planned Board Size (W x L)</span><div class=\"board-box\">{{ board_w|int }} x {{ board_l|int }}</div></td>\n                <td><span class=\"lbl\">Calc. Unit Weight (Grams)</span><div class=\"board-box\" style=\"background:#f9f9f9; color:#2B3990;\">{{ \"%.2f\" % unit_weight }}g</div></td>\n                <td><span class=\"lbl\">Actual Board Size</span><div class=\"board-box\" style=\"border-color:#999; color:#999;\">____ x ____</div></td>\n            </tr>\n        </table>\n\n        <div class=\"sec-head alt\">4. Panel & Flap Dimensions (Creasing Layout)</div>\n        <table class=\"dense-table\">\n            <tr><th width=\"15%\">TYPE</th><th>PART 1</th><th>PART 2</th><th>PART 3</th><th>PART 4</th><th>TAB</th><th>TOTAL</th></tr>\n            <tr>\n                <td style=\"background:#f9f9f9; font-weight:900;\">FLAP/H</td>\n                <td>{{ flap }}</td>\n                <td>{{ H }}</td>\n                <td>{{ flap }}</td>\n                <td>-</td><td>-</td>\n                <td style=\"background:#eee;\">{{ (flap * 2) + H }}</td>\n            </tr>\n            <tr>\n                <td style=\"background:#f9f9f9; font-weight:900;\">PANEL</td>\n                <td>{{ L }}</td>\n                <td>{{ W }}</td>\n                <td>{{ L }}</td>\n                <td>{{ W }}</td>\n                <td>30</td>\n                <td style=\"background:#eee;\">{{ board_l|int }}</td>\n            </tr>\n        </table>\n\n        {#- SVG die-cut visualization generated by Python utility -#}\n        {%- set carton_svg = get_carton_svg(doc) -%}\n        {%- if carton_svg -%}\n        <table class=\"dense-table\">\n            <tr>\n                <td style=\"text-align:center; padding:8px; background:#fff;\">\n                    <div class=\"die-cut-container\">\n                        {{ carton_svg }}\n                    </div>\n                </td>\n            </tr>\n        </table>\n        <table width=\"100%\" style=\"margin-top:20px;\">\n            <tr>\n                <td align=\"center\" width=\"33%\"><div class=\"sig-line\"></div><span class=\"lbl\">Sales Rep</span></td>\n                <td align=\"center\" width=\"34%\"><div class=\"sig-line\"></div><span class=\"lbl\">Management</span></td>\n                <td align=\"center\" width=\"33%\"><div class=\"sig-line\"></div><span class=\"lbl\">Production Manager</span></td>\n            </tr>\n        </table>\n    </div>\n\n    <div class=\"page-break\"></div>\n\n    <!-- PAGE 2: PRODUCTION LOG & REEL TRACKING -->\n    <div class=\"page-container\">\n        <table class=\"header-table\">\n            <tr>\n                <td><div class=\"main-title\">Production Log & Reel Tracking</div></td>\n                <td align=\"right\" width=\"25%\"><div style=\"border: 1px solid #2B3990; padding: 4px; text-align: center;\"><span class=\"lbl\">JOB NO:</span> <span class=\"val\">{{ doc.name }}</span></div></td>\n            </tr>\n        </table>\n\n        <table class=\"sub-header-grid\">\n            <tr>\n                <td class=\"k\">Customer</td><td>{{ doc.get(\"customer_name\") }}</td>\n                <td class=\"k\">Job Name</td><td>{{ doc.get(\"job_description\") or \"N/A\" }}</td>\n            </tr>\n        </table>\n\n        <div class=\"sec-head\">1A. Corrugation (Reel Tracking)</div>\n        <table class=\"dense-table\">\n            <tr><th width=\"20%\">Reel ID</th><th>Start Dia</th><th>End Dia</th><th>Start Wt</th><th>End Wt</th><th>Waste</th><th>Operator</th></tr>\n            {% for i in range(4) %}\n            <tr><td height=\"28\"></td><td></td><td></td><td></td><td></td><td></td><td></td></tr>\n            {% endfor %}\n        </table>\n\n        <div class=\"sec-head alt\">1B. Sheeting & Printing Output</div>\n        <table class=\"dense-table\">\n            <tr><th width=\"30%\">Station</th><th width=\"15%\">Input Qty</th><th width=\"15%\">Output Qty</th><th width=\"20%\">Reject/Waste</th><th width=\"20%\">Operator</th></tr>\n            <tr><td height=\"25\">Sheeting Unit</td><td></td><td></td><td></td><td></td></tr>\n            <tr><td height=\"25\">Printing & Slotting</td><td></td><td></td><td></td><td></td></tr>\n            <tr><td height=\"25\">Pasting / Stitching</td><td></td><td></td><td></td><td></td></tr>\n        </table>\n\n        <div class=\"sec-head dark\">2. Material Reconciliation (QA Verification)</div>\n        <table class=\"dense-table\">\n            <tr><th>Material Item</th><th>Theoretical (KG)</th><th>Actual Used (KG)</th><th>Variance (+/-)</th><th>QA Sign</th></tr>\n            <tr><td height=\"35\">Paper Rolls (Liner/Flute)</td><td></td><td></td><td></td><td></td></tr>\n            <tr><td height=\"35\">Adhesive / Glue / Ink</td><td></td><td></td><td></td><td></td></tr>\n        </table>\n\n        <div class=\"sec-head\">3. Final Dispatch Tally</div>\n        <table class=\"dense-table\">\n            <tr><th>Date</th><th>Vehicle No.</th><th>Bundle Count</th><th>Total Pcs</th><th>Invoice/DN</th><th>Sign</th></tr>\n            <tr><td height=\"25\"></td><td></td><td></td><td></td><td></td><td></td></tr>\n            <tr><td height=\"25\"></td><td></td><td></td><td></td><td></td><td></td></tr>\n        </table>\n    </div>\n\n    <div class=\"page-break\"></div>\n\n    <!-- PAGE 3: QC CHECKLIST -->\n    <div class=\"page-container\">\n        <table class=\"header-table\">\n            <tr>\n                <td><div class=\"main-title\">QC Production Checklist (5-Day Log)</div></td>\n                <td align=\"right\" width=\"25%\"><div style=\"border: 1px solid #2B3990; padding: 4px; text-align: center;\"><span class=\"lbl\">JOB NO:</span> <span class=\"val\">{{ doc.name }}</span></div></td>\n            </tr>\n        </table>\n\n        <table class=\"sub-header-grid\">\n            <tr>\n                <td class=\"k\">Customer</td><td>{{ doc.get(\"customer_name\") }}</td>\n                <td class=\"k\">Job Name</td><td>{{ doc.get(\"job_description\") or \"N/A\" }}</td>\n            </tr>\n        </table>\n\n        <table class=\"dense-table\">\n            <thead>\n                <tr>\n                    <th width=\"35%\">INSPECTION STAGE</th>\n                    <th>RUN 1</th><th>RUN 2</th><th>RUN 3</th><th>RUN 4</th><th>RUN 5</th>\n                </tr>\n            </thead>\n            <tbody>\n                <tr><td>1. RAW MATERIAL <br><small>Moisture, GSM Check</small></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td></tr>\n                <tr><td>2. PRE-PRESS <br><small>Stereo/Die Alignment</small></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td></tr>\n                <tr><td>3. PRINTING & SLOTTING <br><small>Color Match, Ink Coverage</small></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td></tr>\n                <tr><td>4. DIE-CUTTING <br><small>Creasing Depth, Clean Cuts</small></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td></tr>\n                <tr><td>5. GLUING/STITCHING <br><small>Bond Strength, Squaring</small></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td></tr>\n                <tr><td>6. FINISHED CARTON <br><small>Bursting/Compression Check</small></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td></tr>\n                <tr><td>7. PACKING/LABELLING <br><small>Correct Bundle Count</small></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td></tr>\n                <tr style=\"height:50px;\">\n                    <td style=\"background:#eee; font-weight:900;\">SUPERVISOR SIGN-OFF</td>\n                    <td></td><td></td><td></td><td></td><td></td>\n                </tr>\n            </tbody>\n        </table>\n\n        <div style=\"margin-top:15px; font-size: 9.5px; border: 1.5px solid #000; padding: 10px; background: #f9f9f9;\">\n            <strong>AQL STANDARDS:</strong> Critical Defects: 0.0 | Major Defects: 1.0 | Minor Defects: 2.5. <br>\n            <strong>PROCEDURE:</strong> Perform First-off approval at start of run, then random sampling every 60 minutes. Log any deviations in the Production Remarks section of the Job Card.\n        </div>\n    </div>\n</div>\n"
 }
]