[
 {
  "name": "Carton Job Card",
  "doctype": "Print Format",
  "doc_type": "Job Card Carton",
  "module": "Job Card Tracking",
  "print_format_type": "Jinja",
  "raw_printing": 0,
  "standard": "No",
  "custom_format": 1,
  "html": "<style>\n    /* GLOBAL PRINT SETTINGS */\n    @page { size: A4; margin: 10mm; }\n    .vcl-wrapper { font-family: 'Inter', Arial, sans-serif; color: #000; font-size: 10.5px; line-height: 1.2; }\n    .page-break { page-break-before: always; }\n\n    /* BRANDING & HEADERS */\n    .header-table { width: 100%; border-bottom: 3px solid #2B3990; margin-bottom: 8px; padding-bottom: 4px; }\n    .main-title { color: #2B3990; font-size: 20px; font-weight: 900; text-transform: uppercase; }\n    .sec-head { background: #2B3990; color: #fff; padding: 5px 8px; font-weight: 900; font-size: 10px; text-transform: uppercase; border-radius: 2px 2px 0 0; margin-top: 8px; }\n    .sec-head.alt { background: #00395D; }\n    .sec-head.dark { background: #333; }\n\n    /* BOXED GRID SYSTEM */\n    .dense-table { width: 100%; border-collapse: collapse; margin-bottom: 5px; table-layout: fixed; }\n    .dense-table td, .dense-table th { border: 1.5px solid #666; padding: 6px; vertical-align: top; word-wrap: break-word; }\n    .dense-table th { background: #eee; text-align: left; font-weight: 900; font-size: 9px; text-transform: uppercase; }\n\n    /* LABELS & VALUES */\n    .lbl { font-size: 8px; color: #00395D; font-weight: 900; text-transform: uppercase; display: block; margin-bottom: 2px; }\n    .val { font-weight: 900; color: #000; font-size: 12px; }\n    .board-box { border: 2px solid #000; padding: 8px; text-align: center; font-size: 16px; font-weight: 900; background: #fff; margin-top: 4px; }\n    .sig-line { border-top: 1.5px solid #000; width: 85%; margin: 20px auto 5px auto; }\n\n    /* SUB-HEADER FOR PAGES 2 & 3 */\n    .sub-header-grid { width: 100%; border-collapse: collapse; margin-bottom: 10px; }\n    .sub-header-grid td { border: 1px solid #ccc; padding: 4px 8px; font-size: 9px; }\n    .sub-header-grid .k { background: #f4f4f4; font-weight: 900; width: 15%; text-transform: uppercase; }\n\n    .qc-box { width: 15px; height: 15px; border: 1.5px solid #000; margin: 2px auto; }\n\n    /* DIE-CUT VISUALIZATION */\n    .die-cut-container { text-align: center; padding: 8px 0; }\n    .die-cut-container svg { max-width: 100%; }\n</style>\n\n{%- set board_w = doc.get(\"board_width_planned_mm\") | float if doc.get(\"board_width_planned_mm\") else 0 -%}\n{%- set board_l = doc.get(\"board_length_planned_mm\") | float if doc.get(\"board_length_planned_mm\") else 0 -%}\n{%- set area = (board_w / 1000.0) * (board_l / 1000.0) -%}\n\n{#- Take-up Factor Logic -#}\n{%- set flute_type = (doc.get(\"flute_type\") or \"\").upper() -%}\n{%- set factor = 1.7 if \"E\" in flute_type else 1.5 -%}\n\n{#- GSM Layers -#}\n{%- set gsm1 = doc.get(\"1_ply_top_layer_gsm\") | float if doc.get(\"1_ply_top_layer_gsm\") else 0 -%}\n{%- set gsm2 = doc.get(\"2_ply_fluting_gsm\") | float if doc.get(\"2_ply_fluting_gsm\") else 0 -%}\n{%- set gsm3 = doc.get(\"3_ply_bottom_gsm\") | float if doc.get(\"3_ply_bottom_gsm\") else 0 -%}\n{%- set gsm4 = doc.get(\"4_ply_fluting_gsm\") | float if doc.get(\"4_ply_fluting_gsm\") else 0 -%}\n{%- set gsm5 = doc.get(\"5_ply_fluting_gsm\") | float if doc.get(\"5_ply_fluting_gsm\") else 0 -%}\n\n{%- set ply = doc.get(\"ply\") or \"\" -%}\n{%- if ply == \"5\" -%}\n    {%- set unit_weight = (area * gsm1) + (area * gsm2 * factor) + (area * gsm3) + (area * gsm4 * factor) + (area * gsm5) -%}\n{%- else -%}\n    {%- set unit_weight = (area * gsm1) + (area * gsm2 * factor) + (area * gsm3) -%}\n{%- endif -%}\n\n{#- Material display string -#}\n{%- set mat1 = doc.get(\"1_ply_top_layer_material\") or \"\" -%}\n{%- set mat3 = doc.get(\"3_ply_top_layer_material\") or \"\" -%}\n\n{#- Product type for conditional rendering -#}\n{%- set product_type = doc.get(\"product_type\") or \"\" -%}\n{%- set joint_type = doc.get(\"joint_type\") or \"\" -%}\n{%- set L = doc.get(\"ctn_length_mm\") | int if doc.get(\"ctn_length_mm\") else 0 -%}\n{%- set W = doc.get(\"ctn_width_mm\") | int if doc.get(\"ctn_width_mm\") else 0 -%}\n{%- set H = doc.get(\"ctn_height_mm\") | int if doc.get(\"ctn_height_mm\") else 0 -%}\n{%- set flap = doc.get(\"ctn_flap_mm\") | int if doc.get(\"ctn_flap_mm\") else 0 -%}\n\n<div class=\"vcl-wrapper\">\n\n    <!-- PAGE 1: MASTER AUTHORIZATION -->\n    <div class=\"page-container\">\n        <table class=\"header-table\">\n            <tr>\n                <td>\n                    <div class=\"main-title\">Carton Job Traveler</div>\n                    <div style=\"font-size:10px; font-weight:900; color:#00395D;\">VIMIT CONVERTERS LTD &bull; MASTER AUTHORIZATION</div>\n                </td>\n                <td align=\"right\" width=\"30%\">\n                    <div style=\"border: 2px solid #2B3990; padding: 5px; text-align: center;\">\n                        <span class=\"lbl\">JOB CARD NO:</span>\n                        <div style=\"font-size: 16px; font-weight: 900; color: #2B3990;\">{{ doc.name }}</div>\n                    </div>\n                </td>\n            </tr>\n        </table>\n\n        <div class=\"sec-head\">1. Commercial & Order Details</div>\n        <table class=\"dense-table\">\n            <tr>\n                <td colspan=\"3\">\n                    <span class=\"lbl\">Customer Name</span>\n                    <span class=\"val\">{{ doc.get(\"customer_name\") or \"INTERNAL / STOCK\" }}</span>\n                    <div style=\"margin-top: 8px; border-top: 1px dashed #ccc; padding-top: 4px;\">\n                        <span class=\"lbl\">Job Description / Specific Remarks</span>\n                        <span class=\"val\" style=\"font-size: 11px; color: #333;\">{{ doc.get(\"specification_name\") or \"N/A\" }}</span>\n                    </div>\n                </td>\n                <td>\n                    <span class=\"lbl\">Order / LPO No.</span>\n                    <span class=\"val\">________________</span>\n                    <div style=\"margin-top: 15px;\">\n                        <span class=\"lbl\">New / Repeat</span>\n                        <span class=\"val\">{{ doc.get(\"repeat\") or \"NEW\" }}</span>\n                    </div>\n                </td>\n            </tr>\n            <tr>\n                <td><span class=\"lbl\">Qty Ordered</span><span class=\"val\" style=\"font-size:16px;\">{{ doc.get(\"quantity_ordered\") or \"0\" }} PCS</span></td>\n                <td><span class=\"lbl\">Due Date</span><span class=\"val\">{{ frappe.utils.formatdate(doc.get(\"due_date\"), \"dd.mm.yyyy\") if doc.get(\"due_date\") else \"\" }}</span></td>\n                <td><span class=\"lbl\">Colours</span><span class=\"val\">{{ doc.get(\"colours_details\") or \"PLAIN\" }}</span></td>\n                <td><span class=\"lbl\">Date Created</span><span class=\"val\">{{ frappe.utils.formatdate(doc.creation, \"dd.mm.yyyy\") }}</span></td>\n            </tr>\n        </table>\n\n        <div class=\"sec-head alt\">2. Product Specifications (Carton Size)</div>\n        <table class=\"dense-table\">\n            <tr>\n                <td><span class=\"lbl\">Length (mm)</span><span class=\"val\">{{ L }}</span></td>\n                <td><span class=\"lbl\">Width (mm)</span><span class=\"val\">{{ W }}</span></td>\n                <td><span class=\"lbl\">Height (mm)</span><span class=\"val\">{{ H }}</span></td>\n                <td><span class=\"lbl\">Flap (mm)</span><span class=\"val\">{{ flap }}</span></td>\n                <td><span class=\"lbl\">Ply</span><span class=\"val\" style=\"font-size:16px;\">{{ ply or \"N/A\" }}</span></td>\n            </tr>\n            <tr>\n                <td colspan=\"2\">\n                    <span class=\"lbl\">Paper Combination / GSM Detail</span>\n                    <span class=\"val\">\n                        {%- if ply == \"5\" -%}\n                            {{ gsm1|int }} {{ mat1 }} / {{ gsm2|int }}F / {{ gsm3|int }} {{ mat3 }} / {{ gsm4|int }}F / {{ gsm5|int }}\n                        {%- elif ply == \"3\" -%}\n                            {{ gsm1|int }} {{ mat1 }} / {{ gsm2|int }}F / {{ gsm3|int }} {{ mat3 }}\n                        {%- elif ply == \"SFK\" -%}\n                            {{ gsm1|int }} {{ mat1 }} / {{ gsm2|int }}F\n                        {%- else -%}\n                            N/A\n                        {%- endif -%}\n                    </span>\n                </td>\n                <td><span class=\"lbl\">Flute Type</span><span class=\"val\">{{ doc.get(\"flute_type\") or \"N/A\" }}</span></td>\n                <td><span class=\"lbl\">Joint Type</span><span class=\"val\">{{ joint_type or \"N/A\" }}</span></td>\n                <td><span class=\"lbl\">Product Type</span><span class=\"val\">{{ product_type or \"N/A\" }}</span></td>\n            </tr>\n        </table>\n\n        <div class=\"sec-head\">3. Board Production & Calculated Weight</div>\n        <table class=\"dense-table\">\n            <tr>\n                <td><span class=\"lbl\">Planned Board Size (W x L)</span><div class=\"board-box\">{{ board_w|int }} x {{ board_l|int }}</div></td>\n                <td><span class=\"lbl\">Calc. Unit Weight (Grams)</span><div class=\"board-box\" style=\"background:#f9f9f9; color:#2B3990;\">{{ \"%.2f\" % unit_weight }}g</div></td>\n                <td><span class=\"lbl\">Actual Board Size</span><div class=\"board-box\" style=\"border-color:#999; color:#999;\">____ x ____</div></td>\n            </tr>\n        </table>\n\n        <div class=\"sec-head alt\">4. Panel & Flap Dimensions (Creasing Layout)</div>\n        <table class=\"dense-table\">\n            <tr><th width=\"15%\">TYPE</th><th>PART 1</th><th>PART 2</th><th>PART 3</th><th>PART 4</th><th>TAB</th><th>TOTAL</th></tr>\n            <tr>\n                <td style=\"background:#f9f9f9; font-weight:900;\">FLAP/H</td>\n                <td>{{ flap }}</td>\n                <td>{{ H }}</td>\n                <td>{{ flap }}</td>\n                <td>-</td><td>-</td>\n                <td style=\"background:#eee;\">{{ (flap * 2) + H }}</td>\n            </tr>\n            <tr>\n                <td style=\"background:#f9f9f9; font-weight:900;\">PANEL</td>\n                <td>{{ L }}</td>\n                <td>{{ W }}</td>\n                <td>{{ L }}</td>\n                <td>{{ W }}</td>\n                <td>30</td>\n                <td style=\"background:#eee;\">{{ board_l|int }}</td>\n            </tr>\n        </table>\n\n        {#- SVG die-cut visualization generated by Python utility -#}\n        {%- set carton_svg = get_carton_svg(doc) -%}\n        {%- if carton_svg -%}\n        <table class=\"dense-table\">\n            <tr>\n                <td style=\"text-align:center; padding:8px; background:#fff;\">\n                    <div class=\"die-cut-container\">\n                        {{ carton_svg }}\n                    </div>\n                </td>\n            </tr>\n        </table>\n        {%- endif -%}\n\n        <table width=\"100%\" style=\"margin-top:20px;\">\n            <tr>\n                <td align=\"center\" width=\"33%\"><div class=\"sig-line\"></div><span class=\"lbl\">Sales Rep</span></td>\n                <td align=\"center\" width=\"34%\"><div class=\"sig-line\"></div><span class=\"lbl\">Management</span></td>\n                <td align=\"center\" width=\"33%\"><div class=\"sig-line\"></div><span class=\"lbl\">Production Manager</span></td>\n            </tr>\n        </table>\n    </div>\n\n    <div class=\"page-break\"></div>\n\n    <!-- PAGE 2: PRODUCTION LOG & REEL TRACKING -->\n    <div class=\"page-container\">\n        <table class=\"header-table\">\n            <tr>\n                <td><div class=\"main-title\">Production Log & Reel Tracking</div></td>\n                <td align=\"right\" width=\"25%\"><div style=\"border: 1px solid #2B3990; padding: 4px; text-align: center;\"><span class=\"lbl\">JOB NO:</span> <span class=\"val\">{{ doc.name }}</span></div></td>\n            </tr>\n        </table>\n\n        <table class=\"sub-header-grid\">\n            <tr>\n                <td class=\"k\">Customer</td><td>{{ doc.get(\"customer_name\") }}</td>\n                <td class=\"k\">Job Name</td><td>{{ doc.get(\"specification_name\") or \"N/A\" }}</td>\n            </tr>\n        </table>\n\n        <div class=\"sec-head\">1A. Corrugation (Reel Tracking)</div>\n        <table class=\"dense-table\">\n            <tr><th width=\"20%\">Reel ID</th><th>Start Dia</th><th>End Dia</th><th>Start Wt</th><th>End Wt</th><th>Waste</th><th>Operator</th></tr>\n            {% for i in range(4) %}\n            <tr><td height=\"28\"></td><td></td><td></td><td></td><td></td><td></td><td></td></tr>\n            {% endfor %}\n        </table>\n\n        <div class=\"sec-head alt\">1B. Sheeting & Printing Output</div>\n        <table class=\"dense-table\">\n            <tr><th width=\"30%\">Station</th><th width=\"15%\">Input Qty</th><th width=\"15%\">Output Qty</th><th width=\"20%\">Reject/Waste</th><th width=\"20%\">Operator</th></tr>\n            <tr><td height=\"25\">Sheeting Unit</td><td></td><td></td><td></td><td></td></tr>\n            <tr><td height=\"25\">Printing & Slotting</td><td></td><td></td><td></td><td></td></tr>\n            <tr><td height=\"25\">Pasting / Stitching</td><td></td><td></td><td></td><td></td></tr>\n        </table>\n\n        <div class=\"sec-head dark\">2. Material Reconciliation (QA Verification)</div>\n        <table class=\"dense-table\">\n            <tr><th>Material Item</th><th>Theoretical (KG)</th><th>Actual Used (KG)</th><th>Variance (+/-)</th><th>QA Sign</th></tr>\n            <tr><td height=\"35\">Paper Rolls (Liner/Flute)</td><td></td><td></td><td></td><td></td></tr>\n            <tr><td height=\"35\">Adhesive / Glue / Ink</td><td></td><td></td><td></td><td></td></tr>\n        </table>\n\n        <div class=\"sec-head\">3. Final Dispatch Tally</div>\n        <table class=\"dense-table\">\n            <tr><th>Date</th><th>Vehicle No.</th><th>Bundle Count</th><th>Total Pcs</th><th>Invoice/DN</th><th>Sign</th></tr>\n            <tr><td height=\"25\"></td><td></td><td></td><td></td><td></td><td></td></tr>\n            <tr><td height=\"25\"></td><td></td><td></td><td></td><td></td><td></td></tr>\n        </table>\n    </div>\n\n    <div class=\"page-break\"></div>\n\n    <!-- PAGE 3: QC CHECKLIST -->\n    <div class=\"page-container\">\n        <table class=\"header-table\">\n            <tr>\n                <td><div class=\"main-title\">QC Production Checklist (5-Day Log)</div></td>\n                <td align=\"right\" width=\"25%\"><div style=\"border: 1px solid #2B3990; padding: 4px; text-align: center;\"><span class=\"lbl\">JOB NO:</span> <span class=\"val\">{{ doc.name }}</span></div></td>\n            </tr>\n        </table>\n\n        <table class=\"sub-header-grid\">\n            <tr>\n                <td class=\"k\">Customer</td><td>{{ doc.get(\"customer_name\") }}</td>\n                <td class=\"k\">Job Name</td><td>{{ doc.get(\"specification_name\") or \"N/A\" }}</td>\n            </tr>\n        </table>\n\n        <table class=\"dense-table\">\n            <thead>\n                <tr>\n                    <th width=\"35%\">INSPECTION STAGE</th>\n                    <th>RUN 1</th><th>RUN 2</th><th>RUN 3</th><th>RUN 4</th><th>RUN 5</th>\n                </tr>\n            </thead>\n            <tbody>\n                <tr><td>1. RAW MATERIAL <br><small>Moisture, GSM Check</small></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td></tr>\n                <tr><td>2. PRE-PRESS <br><small>Stereo/Die Alignment</small></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td></tr>\n                <tr><td>3. PRINTING & SLOTTING <br><small>Color Match, Ink Coverage</small></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td></tr>\n                <tr><td>4. DIE-CUTTING <br><small>Creasing Depth, Clean Cuts</small></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td></tr>\n                <tr><td>5. GLUING/STITCHING <br><small>Bond Strength, Squaring</small></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td></tr>\n                <tr><td>6. FINISHED CARTON <br><small>Bursting/Compression Check</small></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td></tr>\n                <tr><td>7. PACKING/LABELLING <br><small>Correct Bundle Count</small></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td><td><div class=\"qc-box\"></div></td></tr>\n                <tr style=\"height:50px;\">\n                    <td style=\"background:#eee; font-weight:900;\">SUPERVISOR SIGN-OFF</td>\n                    <td></td><td></td><td></td><td></td><td></td>\n                </tr>\n            </tbody>\n        </table>\n\n        <div style=\"margin-top:15px; font-size: 9.5px; border: 1.5px solid #000; padding: 10px; background: #f9f9f9;\">\n            <strong>AQL STANDARDS:</strong> Critical Defects: 0.0 | Major Defects: 1.0 | Minor Defects: 2.5. <br>\n            <strong>PROCEDURE:</strong> Perform First-off approval at start of run, then random sampling every 60 minutes. Log any deviations in the Production Remarks section of the Job Card.\n        </div>\n    </div>\n</div>\n"
 },
 {
  "name": "Label Job Traveller",
  "doctype": "Print Format",
  "doc_type": "Job Card Label",
  "module": "Job Card Tracking",
  "print_format_type": "Jinja",
  "raw_printing": 0,
  "standard": "No",
  "custom_format": 1,
  "default_print_language": "en",
  "html": "<style>\n    * { margin: 0; padding: 0; box-sizing: border-box; -webkit-print-color-adjust: exact; }\n\n    @media print {\n        .print-format { padding: 0px !important; margin: 0px !important; }\n        @page { size: A4 portrait; margin: 6mm; }\n        .page-break { page-break-before: always; }\n    }\n\n    .print-format {\n        font-family: \"Helvetica Neue\", Helvetica, Arial, sans-serif;\n        font-size: 8.2pt;\n        color: #000;\n        line-height: 1.1;\n        background: #FFF;\n    }\n\n    .page-container {\n        width: 100%;\n        display: block;\n        padding: 2mm 0mm;\n        page-break-after: always;\n    }\n\n    .vcl-header-table {\n        width: 100%;\n        border-bottom: 2.5pt solid #2B3990;\n        margin-bottom: 6px;\n        padding-bottom: 4px;\n    }\n\n    .company-title {\n        font-size: 16pt;\n        font-weight: 800;\n        color: #2B3990;\n        letter-spacing: 0.5px;\n        text-transform: uppercase;\n    }\n\n    .job-badge {\n        background-color: #2B3990;\n        color: #FFFFFF;\n        padding: 5px 12px;\n        font-size: 11pt;\n        font-weight: bold;\n        text-align: center;\n        border-radius: 2px;\n    }\n\n    .job-type-indicator {\n        font-size: 10pt;\n        font-weight: 900;\n        color: #00395D;\n        text-transform: uppercase;\n        margin-top: 5px;\n    }\n\n    .section-header-compact {\n        background-color: #2B3990;\n        color: #FFF;\n        padding: 3px 10px;\n        font-weight: bold;\n        text-transform: uppercase;\n        margin-top: 8px;\n        font-size: 8.5pt;\n    }\n\n    .subheader-vcl {\n        background-color: #00395D;\n        color: #FFF;\n        padding: 2px 8px;\n        font-weight: bold;\n        font-size: 8pt;\n        margin-top: 5px;\n    }\n\n    .vcl-table-compact {\n        width: 100%;\n        border-collapse: collapse;\n        margin-top: 2px;\n        table-layout: fixed;\n    }\n\n    .vcl-table-compact td, .vcl-table-compact th {\n        border: 0.8pt solid #000;\n        padding: 3px 5px;\n        vertical-align: middle;\n        word-wrap: break-word;\n    }\n\n    .label-cell-compact {\n        background-color: #F4F4F4;\n        font-weight: bold;\n        width: 18%;\n    }\n\n    .highlight-cell {\n        background-color: #e8ebff !important;\n        font-weight: bold;\n        color: #2B3990;\n    }\n\n    .example-row {\n        background-color: #f1f4ff !important;\n        font-style: italic;\n        color: #2B3990;\n        font-weight: bold;\n        font-size: 7.8pt;\n    }\n\n    .manual-entry-row { height: 26px; }\n\n    .colour-chip {\n        display: inline-block;\n        width: 11px;\n        height: 11px;\n        border: 0.8pt solid #555;\n        border-radius: 2px;\n        vertical-align: middle;\n        margin-right: 4px;\n    }\n\n    .colour-pill {\n        display: inline-block;\n        padding: 1px 6px 1px 4px;\n        margin: 1px 2px;\n        border: 0.6pt solid #999;\n        border-radius: 8px;\n        font-size: 7.8pt;\n        background: #FAFAFA;\n    }\n\n    .sop-list {\n        font-size: 8pt;\n        margin: 4px 8px 0 20px;\n        line-height: 1.35;\n    }\n    .sop-list li { margin-bottom: 3px; }\n\n    .qc-box { width: 14px; height: 14px; border: 1pt solid #000; margin: 2px auto; }\n</style>\n\n<div class=\"print-format\">\n\n    <!-- ============================================================\n         PAGE 1 · MASTER AUTHORIZATION\n         ============================================================ -->\n    <div class=\"page-container\">\n        <table class=\"vcl-header-table\">\n            <tr>\n                <td>\n                    <div class=\"company-title\">VIMIT CONVERTERS LIMITED</div>\n                    <div style=\"font-weight: bold; font-size: 10pt;\">LABEL JOB TRAVELLER: {{ doc.name }}</div>\n                    <div class=\"job-type-indicator\">\n                        JOB TYPE:\n                        {% if doc.amended_from %}REPEAT JOB{% else %}NEW JOB{% endif %}\n                    </div>\n                </td>\n                <td style=\"text-align: right; width: 30%;\">\n                    <div class=\"job-badge\">{{ doc.name }}</div>\n                    <div style=\"margin-top: 4px; font-size: 9pt;\">\n                        Due Date: <span style=\"color: #CC0000; font-weight: bold;\">{{ frappe.utils.formatdate(doc.due_date, \"dd-MMM-yy\") }}</span>\n                    </div>\n                </td>\n            </tr>\n        </table>\n\n        <div class=\"section-header-compact\">1. JOB INFORMATION</div>\n        <table class=\"vcl-table-compact\">\n            <tr>\n                <td class=\"label-cell-compact\">Customer:</td>\n                <td><strong>{{ doc.customer }}</strong></td>\n                <td class=\"label-cell-compact\">Order Date:</td>\n                <td>{{ frappe.utils.formatdate(doc.order_date, \"dd-MMM-yy\") }}</td>\n            </tr>\n            <tr>\n                <td class=\"label-cell-compact\">LPO No.:</td>\n                <td>{{ doc.lpo_number or \"—\" }}</td>\n                <td class=\"label-cell-compact\">Sales Rep:</td>\n                <td>{{ doc.sales_rep or \"—\" }}</td>\n            </tr>\n        </table>\n\n        <div class=\"section-header-compact\">2. PRODUCT SPECIFICATION</div>\n        <table class=\"vcl-table-compact\">\n            <tr>\n                <td class=\"label-cell-compact\">Product Spec:</td>\n                <td style=\"width: 32%;\"><strong>{{ doc.customer_product_spec }}</strong></td>\n                <td class=\"label-cell-compact\">Spec Name:</td>\n                <td style=\"width: 32%;\">{{ doc.specification_name }}</td>\n            </tr>\n            <tr>\n                <td class=\"label-cell-compact\">Job Size:</td>\n                <td>{{ doc.job_size }}</td>\n                <td class=\"label-cell-compact\">Qty Ordered:</td>\n                <td><strong>{{ \"{:,}\".format(doc.quantity_ordered) if doc.quantity_ordered else 0 }}</strong></td>\n            </tr>\n            <tr>\n                <td class=\"label-cell-compact\">Plate Status:</td>\n                <td class=\"highlight-cell\">{{ doc.plate_status or \"Check Spec\" }}{% if doc.plate_code %} &middot; <span style=\"font-weight:normal;\">{{ doc.plate_code }}</span>{% endif %}</td>\n                <td class=\"label-cell-compact\">Material:</td>\n                <td>{{ doc.material_type }}</td>\n            </tr>\n        </table>\n\n        <div class=\"subheader-vcl\">PRINT COLOURS</div>\n        <table class=\"vcl-table-compact\">\n            <tr>\n                <td class=\"label-cell-compact\">Ink Type:</td>\n                <td style=\"width: 20%;\"><strong>{{ doc.ink_type or \"—\" }}</strong></td>\n                <td class=\"label-cell-compact\">Count:</td>\n                <td style=\"width: 15%;\" class=\"highlight-cell\">{{ doc.number_of_colours or 0 }} colour{% if (doc.number_of_colours or 0) != 1 %}s{% endif %}</td>\n                <td class=\"label-cell-compact\">Process:</td>\n                <td>\n                    {% set _cmyk = [] %}\n                    {% if doc.uses_c %}{% set _ = _cmyk.append(\"C\") %}{% endif %}\n                    {% if doc.uses_m %}{% set _ = _cmyk.append(\"M\") %}{% endif %}\n                    {% if doc.uses_y %}{% set _ = _cmyk.append(\"Y\") %}{% endif %}\n                    {% if doc.uses_k %}{% set _ = _cmyk.append(\"K\") %}{% endif %}\n                    {% if _cmyk %}<strong>{{ _cmyk | join(\"\") }}</strong>{% else %}—{% endif %}\n                </td>\n            </tr>\n            <tr>\n                <td class=\"label-cell-compact\">Spot Inks:</td>\n                <td colspan=\"5\">\n                    {% set _spots = doc.spot_colours or [] %}\n                    {% if _spots %}\n                        {% for s in _spots %}\n                            <span class=\"colour-pill\">\n                                <span class=\"colour-chip\" style=\"background: {{ s.hex_preview or '#FFF' }};\"></span>\n                                <strong>{{ s.pantone_name or s.pantone_code or \"—\" }}</strong>\n                                {% if s.pantone_code and s.pantone_name and (s.pantone_code not in (s.pantone_name or '')) %}&middot; {{ s.pantone_code }}{% endif %}\n                                {% if s.cmyk_c or s.cmyk_m or s.cmyk_y or s.cmyk_k %}\n                                    &middot; C{{ s.cmyk_c|int }} M{{ s.cmyk_m|int }} Y{{ s.cmyk_y|int }} K{{ s.cmyk_k|int }}\n                                {% endif %}\n                                {% if s.notes %}&middot; <em>{{ s.notes }}</em>{% endif %}\n                            </span>\n                        {% endfor %}\n                    {% else %}\n                        <em>No spot inks</em>\n                    {% endif %}\n                </td>\n            </tr>\n            {% if doc.colour_notes %}\n            <tr>\n                <td class=\"label-cell-compact\">Notes:</td>\n                <td colspan=\"5\" style=\"font-size: 7.8pt; font-style: italic;\">{{ doc.colour_notes }}</td>\n            </tr>\n            {% endif %}\n        </table>\n\n        <div class=\"subheader-vcl\">TECHNICAL SNAPSHOT & DIMENSIONS</div>\n        <table class=\"vcl-table-compact\">\n            <tr>\n                <td class=\"label-cell-compact\">Label Length:</td><td>{{ doc.label_length }} mm</td>\n                <td class=\"label-cell-compact\">Plate Up:</td><td><strong>{{ doc.plate_up }} LANES</strong></td>\n                <td class=\"label-cell-compact\">Cylinder:</td><td>{{ doc.cylinder_teeth }} T</td>\n            </tr>\n            <tr>\n                <td class=\"label-cell-compact\">Label Width:</td><td>{{ doc.label_width }} mm</td>\n                <td class=\"label-cell-compact\">Plate Round:</td><td>{{ doc.plate_round }}</td>\n                <td class=\"label-cell-compact\">Gap:</td><td>{{ doc.gap_between }} mm</td>\n            </tr>\n            <tr>\n                <td class=\"label-cell-compact highlight-cell\">Approx Reel Width:</td>\n                <td class=\"highlight-cell\">\n                    {% if doc.label_width and doc.plate_up %}\n                        {{ (doc.label_width | float) * (doc.plate_up | float) }} mm\n                    {% else %}\n                        TBD\n                    {% endif %}\n                </td>\n                <td class=\"label-cell-compact\">Side Trim:</td><td>{{ doc.side_trim }} mm</td>\n                <td class=\"label-cell-compact\">Packing Pcs:</td><td>{{ doc.packing_pieces }}</td>\n            </tr>\n        </table>\n\n        <div class=\"section-header-compact\">3. PRE-PRODUCTION QC APPROVAL (FIRST-OFF)</div>\n        <table class=\"vcl-table-compact\">\n            <tr style=\"background: #F4F4F4; font-weight: bold; text-align: center;\">\n                <td style=\"width: 40%;\">Check Item</td><td>Status (OK/FAIL)</td><td>QC Signature</td><td>Remarks</td>\n            </tr>\n            <tr class=\"manual-entry-row\"><td>Plate condition / verification</td><td></td><td></td><td></td></tr>\n            <tr class=\"manual-entry-row\"><td>Shade matching vs. approved sample</td><td></td><td></td><td></td></tr>\n            <tr class=\"manual-entry-row\"><td>Barcode / text clarity (ANSI grade ≥ B)</td><td></td><td></td><td></td></tr>\n            <tr class=\"manual-entry-row\"><td>Registration &amp; colour alignment</td><td></td><td></td><td></td></tr>\n            <tr class=\"manual-entry-row\"><td>Die-cut shape &amp; dimensions</td><td></td><td></td><td></td></tr>\n            <tr class=\"manual-entry-row\"><td>Adhesive / release liner integrity</td><td></td><td></td><td></td></tr>\n        </table>\n\n        <div style=\"margin-top: 28px; border: 2pt solid #2B3990; padding: 16px;\">\n            <div style=\"font-size: 11pt; font-weight: bold; color: #2B3990; margin-bottom: 12px; text-transform: uppercase;\">Final Authorization to Run</div>\n            <table style=\"width: 100%; font-size: 9pt;\">\n                <tr>\n                    <td style=\"width: 45%; border-bottom: 0.8pt solid #000;\">SALES / ACCOUNTS:</td>\n                    <td style=\"width: 10%;\"></td>\n                    <td style=\"width: 45%; border-bottom: 0.8pt solid #000;\">PROD. MANAGER:</td>\n                </tr>\n                <tr><td colspan=\"3\" style=\"height: 32px;\"></td></tr>\n                <tr>\n                    <td style=\"border-bottom: 0.8pt solid #000;\">PLATE RELEASE:</td>\n                    <td></td>\n                    <td style=\"border-bottom: 0.8pt solid #000;\">CYLINDER RELEASE:</td>\n                </tr>\n            </table>\n        </div>\n    </div>\n\n    <!-- ============================================================\n         PAGE 2 · MATERIAL + LABOUR + OPERATOR SOP\n         ============================================================ -->\n    <div class=\"page-container page-break\">\n        <table class=\"vcl-header-table\">\n            <tr>\n                <td><div class=\"company-title\">PRINTING PRODUCTION LOG (PAGE 2)</div></td>\n                <td style=\"text-align: right;\"><strong>{{ doc.name }}</strong></td>\n            </tr>\n        </table>\n\n        <div class=\"subheader-vcl\">SECTION 4 · MATERIAL USAGE &amp; PRINTED OUTPUT (MASTER REELS)</div>\n        <table class=\"vcl-table-compact\" style=\"text-align: center;\">\n            <thead>\n                <tr style=\"background: #F4F4F4; font-weight: bold;\">\n                    <td style=\"width: 15%;\">RAW BATCH</td>\n                    <td style=\"width: 12%;\">START MTRS</td>\n                    <td style=\"width: 12%;\">END MTRS</td>\n                    <td style=\"width: 12%;\">USED MTRS</td>\n                    <td style=\"width: 16%;\">ASSIGNED REEL ID</td>\n                    <td>WASTE / REMARKS</td>\n                    <td style=\"width: 10%;\">SIGN</td>\n                </tr>\n            </thead>\n            <tbody>\n                <tr class=\"example-row\"><td>B-1001 (Jumbo)</td><td>5000 m</td><td>4200 m</td><td>800 m</td><td>R-0001</td><td>Created 1 Master Reel</td><td>---</td></tr>\n                {% for i in range(1, 11) %}<tr class=\"manual-entry-row\"><td></td><td></td><td></td><td></td><td></td><td></td><td></td></tr>{% endfor %}\n            </tbody>\n        </table>\n\n        <div class=\"subheader-vcl\">SECTION 5 · LABOUR &amp; OPERATOR TIMINGS</div>\n        <table class=\"vcl-table-compact\" style=\"font-size: 7.2pt; text-align: center;\">\n            <thead>\n                <tr style=\"background: #F4F4F4; font-weight: bold;\">\n                    <td rowspan=\"2\" style=\"width: 10%;\">DATE</td>\n                    <td rowspan=\"2\" style=\"width: 22%;\">OPERATOR NAME</td>\n                    <td colspan=\"2\">SETTING TIME</td>\n                    <td colspan=\"2\">ACTUAL RUN</td>\n                    <td rowspan=\"2\" style=\"width: 10%;\">DT (HRS)</td>\n                    <td rowspan=\"2\" style=\"width: 15%;\">SHIFT</td>\n                </tr>\n                <tr style=\"background: #F4F4F4; font-weight: bold;\">\n                    <td>START</td><td>END</td><td>START</td><td>END</td>\n                </tr>\n            </thead>\n            <tbody>\n                {% for i in range(1, 11) %}<tr style=\"height:24px;\"><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td></tr>{% endfor %}\n            </tbody>\n        </table>\n\n        <div class=\"section-header-compact\">SECTION 6 · OPERATOR SOP (LABEL PRESS)</div>\n        <table class=\"vcl-table-compact\">\n            <tr>\n                <td class=\"label-cell-compact\" style=\"vertical-align: top; width: 22%;\">A. PRE-RUN SETUP</td>\n                <td>\n                    <ol class=\"sop-list\">\n                        <li>Verify job card details against approved customer artwork &amp; this traveller.</li>\n                        <li>Confirm substrate reel matches <strong>{{ doc.material_type or \"spec\" }}</strong>, width and batch.</li>\n                        <li>Mount plates by code; check for damage, edge chips, or residual ink.</li>\n                        <li>For UV jobs ({{ \"YES\" if doc.ink_type == \"Process UV\" else \"N/A\" }}): verify lamp hours &lt; 1200h; confirm dichroic reflectors clean.</li>\n                        <li>Set anilox roll by BCM / screen count per ink deck; record in log.</li>\n                        <li>Mix inks to recipe shown in <em>Print Colours</em> above; verify viscosity (Zahn #2) and tack.</li>\n                        <li>Load die-cut tooling; confirm cylinder teeth = <strong>{{ doc.cylinder_teeth or \"—\" }}</strong>.</li>\n                    </ol>\n                </td>\n            </tr>\n            <tr>\n                <td class=\"label-cell-compact\" style=\"vertical-align: top;\">B. FIRST ARTICLE</td>\n                <td>\n                    <ol class=\"sop-list\">\n                        <li>Produce a short proof run (≥ 50 labels) at reduced speed.</li>\n                        <li>Check registration on all {{ doc.number_of_colours or \"—\" }} colour{% if (doc.number_of_colours or 0) != 1 %}s{% endif %}; tolerance ≤ 0.15 mm.</li>\n                        <li>Densitometer read: ΔE ≤ 2.0 vs. approved swatch for each spot colour.</li>\n                        <li>Barcode verification: ANSI grade B or better on every SKU.</li>\n                        <li>Die-cut test: clean cut through face stock, liner intact, no feathering.</li>\n                        <li><strong>Do not start the main run until QC signs off the First-Off row in Section 3.</strong></li>\n                    </ol>\n                </td>\n            </tr>\n            <tr>\n                <td class=\"label-cell-compact\" style=\"vertical-align: top;\">C. IN-PROCESS</td>\n                <td>\n                    <ol class=\"sop-list\">\n                        <li>Every reel change: record start / end meters, operator, and time in Section 4.</li>\n                        <li>Every 30 min or every reel: visual check for streaks, ghosting, misregistration, splice breaks.</li>\n                        <li>Every 60 min: densitometer spot-check on each ink; retighten colour if ΔE &gt; 3.0.</li>\n                        <li>Log any downtime &gt; 5 min in Section 5 with cause code.</li>\n                        <li>Tag and separate any waste reels; do NOT release them into finished stock.</li>\n                    </ol>\n                </td>\n            </tr>\n            <tr>\n                <td class=\"label-cell-compact\" style=\"vertical-align: top;\">D. POST-RUN</td>\n                <td>\n                    <ol class=\"sop-list\">\n                        <li>Clean plates with plate-wash; return to plate store with job reference and plate code.</li>\n                        <li>Wash ink decks and anilox rolls; log anilox hours.</li>\n                        <li>Package finished reels with reel ID labels (count, meters, job no., customer).</li>\n                        <li>Retain 3 sample labels in QC retention file (minimum 12 months).</li>\n                        <li>Complete dispatch authorization (Page 3); hand traveller to Production Supervisor.</li>\n                    </ol>\n                </td>\n            </tr>\n        </table>\n    </div>\n\n    <!-- ============================================================\n         PAGE 3 · SLITTING, FINISHING, QC LOG, DISPATCH\n         ============================================================ -->\n    <div class=\"page-container page-break\">\n        <table class=\"vcl-header-table\">\n            <tr>\n                <td><div class=\"company-title\">SLITTING, QC &amp; DISPATCH (PAGE 3)</div></td>\n                <td style=\"text-align: right;\"><strong>{{ doc.name }}</strong></td>\n            </tr>\n        </table>\n\n        <div class=\"subheader-vcl\">SECTION 7 · SLITTING &amp; REWINDING ({{ doc.plate_up or \"?\" }} LANES)</div>\n        <table class=\"vcl-table-compact\" style=\"text-align: center;\">\n            <thead>\n                <tr style=\"background: #F4F4F4; font-weight: bold;\">\n                    <td style=\"width: 11%;\">DATE</td>\n                    <td style=\"width: 14%;\">MASTER REEL ID</td>\n                    <td style=\"width: 11%;\">NO. PASSES</td>\n                    <td style=\"width: 14%;\">ROLLS/PASS</td>\n                    <td style=\"width: 14%;\">TOTAL ROLLS</td>\n                    <td>REMARKS</td>\n                    <td style=\"width: 9%;\">SIGN</td>\n                </tr>\n            </thead>\n            <tbody>\n                {% set _pu = (doc.plate_up | int) if doc.plate_up else 0 %}\n                {% if _pu %}\n                <tr class=\"example-row\">\n                    <td>{{ frappe.utils.formatdate(frappe.utils.nowdate(), \"dd-MMM\") }}</td>\n                    <td>R-0001</td>\n                    <td>12 Passes</td>\n                    <td>{{ _pu }} Rolls</td>\n                    <td>{{ 12 * _pu }} Rolls</td>\n                    <td>Ex: {{ 12 * _pu }} rolls from 1 Master</td>\n                    <td>---</td>\n                </tr>\n                {% endif %}\n                {% for i in range(1, 14) %}<tr style=\"height:24px;\"><td></td><td></td><td></td><td></td><td></td><td></td><td></td></tr>{% endfor %}\n            </tbody>\n        </table>\n\n        <div class=\"section-header-compact\">SECTION 8 · IN-PROCESS QC LOG (EVERY 60 MIN)</div>\n        <table class=\"vcl-table-compact\" style=\"text-align: center;\">\n            <thead>\n                <tr style=\"background: #F4F4F4; font-weight: bold;\">\n                    <td style=\"width: 10%;\">TIME</td>\n                    <td>COLOUR (ΔE)</td>\n                    <td>REGISTRATION</td>\n                    <td>BARCODE (ANSI)</td>\n                    <td>DIE-CUT</td>\n                    <td>ADHESIVE</td>\n                    <td>REMARKS</td>\n                    <td style=\"width: 9%;\">SIGN</td>\n                </tr>\n            </thead>\n            <tbody>\n                {% for i in range(1, 9) %}\n                <tr style=\"height:26px;\">\n                    <td></td>\n                    <td><div class=\"qc-box\"></div></td>\n                    <td><div class=\"qc-box\"></div></td>\n                    <td><div class=\"qc-box\"></div></td>\n                    <td><div class=\"qc-box\"></div></td>\n                    <td><div class=\"qc-box\"></div></td>\n                    <td></td>\n                    <td></td>\n                </tr>\n                {% endfor %}\n            </tbody>\n        </table>\n\n        <div style=\"margin-top: 6px; font-size: 7.8pt; border: 0.8pt solid #000; padding: 6px 10px; background: #f9f9f9;\">\n            <strong>AQL standards:</strong> Critical 0.0 · Major 1.0 · Minor 2.5 &nbsp;&bull;&nbsp;\n            <strong>Colour tolerance:</strong> ΔE ≤ 2.0 (first-off), ΔE ≤ 3.0 (in-process) &nbsp;&bull;&nbsp;\n            <strong>Barcode:</strong> ANSI grade B or better &nbsp;&bull;&nbsp;\n            <strong>Registration:</strong> ≤ 0.15 mm.\n            Log any deviation in Remarks and flag to the Production Supervisor.\n        </div>\n\n        <div style=\"margin-top: 20px; border: 2pt solid #2B3990; padding: 14px;\">\n            <div style=\"font-size: 10pt; font-weight: bold; color: #2B3990; margin-bottom: 10px; text-transform: uppercase;\">QC &amp; Dispatch Authorization</div>\n            <table style=\"width: 100%; font-size: 8.5pt;\">\n                <tr>\n                    <td style=\"width: 45%; border-bottom: 0.8pt solid #000;\">PROD. SUPERVISOR:</td>\n                    <td style=\"width: 10%;\"></td>\n                    <td style=\"width: 45%; border-bottom: 0.8pt solid #000;\">QC FINAL RELEASE:</td>\n                </tr>\n                <tr><td colspan=\"3\" style=\"height: 32px;\"></td></tr>\n                <tr>\n                    <td style=\"border-bottom: 0.8pt solid #000;\">STORES / DISPATCH:</td>\n                    <td></td>\n                    <td style=\"border-bottom: 0.8pt solid #000;\">DATE &amp; TIME:</td>\n                </tr>\n            </table>\n        </div>\n\n        <div style=\"margin-top: 18px; text-align: right; font-size: 7.5pt; color: #666; font-style: italic;\">\n            VCL Production System &middot; Printed: {{ frappe.utils.now_datetime().strftime(\"%d-%b-%Y %I:%M %p\") }}\n        </div>\n    </div>\n</div>\n"
 }
]
